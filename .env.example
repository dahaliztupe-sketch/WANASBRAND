# Email Configuration (Resend)
RESEND_API_KEY=
SMTP_FROM=atelier@wanasbrand.com

# Security — All required, no defaults
SESSION_SECRET=             # Used for JWT session signing (admin auth)
ENCRYPTION_KEY=             # AES-256 key for PII encryption (phone, address)
JWT_SECRET=                 # Token signing for magic links
CRON_SECRET=                # Protects cron job endpoints

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AI — Server-side private key (never expose to client)
GEMINI_API_KEY=

# Sentry Configuration
NEXT_PUBLIC_SENTRY_DSN=

# WhatsApp Configuration
WHATSAPP_API_TOKEN=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
